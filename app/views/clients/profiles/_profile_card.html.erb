<div class="bg-white p-4 rounded-4 shadow-sm">

  <div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="mb-0"><%= title %></h5>

    <% unless editable %>
      <%= link_to edit_clients_profile_path,
        class: "btn btn-soft btn-pill btn-sm d-flex align-items-center gap-1" do %>
        <i class="bi bi-pencil"></i>
        Editar
      <% end %>
    <% end %>
  </div>

  <% if editable %>
    <%= form_with model: user, url: clients_profile_path, method: :patch do |f| %>

      <%= render "users/profile_field",
        label: "Nome",
        value: user.full_name,
        editable: true do %>
        <%= f.text_field :name, class: "form-control" %>
      <% end %>

      <%= render "users/profile_field",
        label: "Telefone",
        value: format_phone(user.phone),
        editable: true do %>
        <%= f.telephone_field :phone,
          class: "form-control",
          inputmode: "numeric",
          pattern: "[0-9]*",
          data: { controller: "phone" } %>
      <% end %>

      <%= render "users/profile_field",
        label: "O que mais te incomoda?",
        value: user.main_discomfort,
        editable: true do %>
        <%= f.text_area :main_discomfort,
          class: "form-control",
          rows: 3 %>
      <% end %>

      <div class="d-flex justify-content-end gap-2 mt-4">
        <%= link_to "Cancelar", clients_profile_path, class: "btn btn-soft btn-pill" %>
        <%= f.submit "Salvar", class: "btn btn-primary btn-pill" %>
      </div>

    <% end %>

  <% else %>

    <%= render "users/profile_field",
      label: "Nome",
      value: user.full_name,
      editable: false %>

    <%= render "users/profile_field",
      label: "Email",
      value: user.email,
      editable: false %>

    <%= render "users/profile_field",
      label: "Telefone",
      value: format_phone(user.phone),
      editable: false %>

    <%= render "users/profile_field",
      label: "O que mais te incomoda?",
      value: user.main_discomfort,
      editable: false %>

  <% end %>

</div>
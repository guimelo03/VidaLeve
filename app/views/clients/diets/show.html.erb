<div class="container py-5" style="max-width: 720px;">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h2 class="mb-1"><%= @diet.title %></h2>

      <small class="text-muted">
        Plano alimentar criado em <%= @diet.created_at.strftime("%d/%m/%Y") %>
      </small>
    </div>

    <%= link_to "Voltar",
      clients_dashboard_path,
      class: "btn btn-soft btn-pill" %>
  </div>

  <% @diet.meals.each do |meal| %>

    <div class="bg-white rounded-4 shadow-sm p-4 mb-4">

      <div class="mb-3">
        <span class="badge bg-light text-dark mb-2">
          Refeição
        </span>

        <h5 class="fw-semibold mb-0">
          <%= meal.name %>
        </h5>
      </div>

      <div class="mt-3">

        <div class="d-flex justify-content-between text-muted small mb-2 px-1">
          <span>Alimento</span>
          <span>Quantidade</span>
        </div>

        <% meal.meal_items.each do |item| %>

          <div class="d-flex justify-content-between align-items-center py-2 px-2 rounded-3 item-row">

            <span class="d-flex align-items-center gap-2">
              <i class="bi bi-dot"></i>
              <%= item.name %>
            </span>

            <span class="badge rounded-pill bg-secondary-subtle text-dark px-3 py-2">
              <%= item.quantity %>
            </span>

          </div>

        <% end %>

      </div>

    </div>

  <% end %>

</div>
<div class="container-lg py-5">

  <div class="mb-4">
    <%= link_to user_profile_path, class: "btn btn-soft btn-pill" do %>
      <i class="bi bi-arrow-left"></i>
      Voltar
    <% end %>
  </div>

  <%= form_with model: @user, url: user_profile_path, method: :patch do |f| %>

    <div class="row">
      <div class="col-lg-8">

        <div class="row">

          <div class="col-md-6 mb-4">
            <%= render "users/profile_section", title: "Dados pessoais" do %>

              <div class="mb-2">
                <strong>Telefone:</strong>
                <%= f.telephone_field :phone,
                  class: "form-control mt-1",
                  inputmode: "numeric",
                  data: { controller: "phone" } %>
              </div>

              <div class="mb-2">
                <strong>Idade:</strong>
                <%= f.number_field :age, class: "form-control mt-1" %>
              </div>

              <div class="mb-2">
                <strong>Sexo:</strong>
                <%= f.select :sex, [["Masculino", "male"], ["Feminino", "female"]],
                  {}, class: "form-control mt-1" %>
              </div>

              <div class="mb-2">
                <strong>Cidade:</strong>
                <%= f.text_field :city, class: "form-control mt-1" %>
              </div>

              <div class="mb-2">
                <strong>Estado:</strong>
                <%= f.text_field :state, class: "form-control mt-1" %>
              </div>

              <div class="mb-2">
                <strong>Profissão:</strong>
                <%= f.text_field :profession, class: "form-control mt-1" %>
              </div>

              <div class="mb-2">
                <strong>Rotina:</strong>
                <%= f.text_area :work_routine, class: "form-control mt-1", rows: 2 %>
              </div>

            <% end %>
          </div>

          <div class="col-md-6 mb-4">
            <%= render "users/profile_section", title: "Informações fisiológicas" do %>

              <div class="mb-2">
                <strong>Peso:</strong>
                <%= f.number_field :current_weight, step: 0.1, class: "form-control mt-1" %>
              </div>

              <div class="mb-2">
                <strong>Altura:</strong>
                <%= f.number_field :height, step: 0.01, class: "form-control mt-1" %>
              </div>

              <div class="mb-2">
                <strong>Circunferência:</strong>
                <%= f.number_field :abdominal_circumference, class: "form-control mt-1" %>
              </div>

              <div class="mb-2">
                <strong>Mediu com fita:</strong><br>
                <%= f.check_box :measured_with_tape %> Sim
              </div>

              <div class="mb-2">
                <strong>Observação:</strong>
                <%= f.text_area :measurement_notes, class: "form-control mt-1", rows: 2 %>
              </div>

              <div class="mb-2">
                <strong>Objetivo:</strong>
                <%= f.select :main_goal,
                  [["Emagrecer", "lose_weight"], ["Hipertrofia", "gain_muscle"], ["Saúde", "improve_health"], ["Manutenção de peso", "maintain"]],
                  {}, class: "form-control mt-1" %>
              </div>

            <% end %>
          </div>

          <div class="col-12">
            <%= render "users/profile_section", title: "O que mais incomoda" do %>

              <%= f.text_area :main_discomfort,
                class: "form-control",
                rows: 3 %>

            <% end %>
          </div>

        </div>
      </div>

      <div class="col-lg-4 d-flex justify-content-end">
        <div class="profile-sidebar me-4">

          <div class="avatar-large mb-3">
            <i class="bi bi-person"></i>
          </div>

          <h4 class="fw-semibold mb-1">
            <%= @user.full_name.presence || @user.email %>
          </h4>

          <p class="text-muted small">
            <%= @user.email %>
          </p>

          <div class="mt-3 d-grid gap-2">
            <%= f.submit "Salvar alterações",
              class: "btn btn-primary btn-pill" %>

            <%= link_to "Cancelar",
              user_profile_path,
              class: "btn btn-soft btn-pill" %>
          </div>

        </div>
      </div>
    </div>

  <% end %>

</div>
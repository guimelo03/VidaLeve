<div class="container py-5" style="max-width: 520px;"
     data-controller="onboarding">

  <div class="onboarding-progress mb-4 d-flex justify-content-center gap-2">

    <div data-onboarding-target="indicator" class="progress-dot active"></div>
    <div data-onboarding-target="indicator" class="progress-dot"></div>
    <div data-onboarding-target="indicator" class="progress-dot"></div>

  </div>

  <div class="mb-4">
    <%= link_to clients_dashboard_path, class: "btn btn-soft px-3 py-2 d-inline-flex align-items-center gap-2" do %>
      <i class="bi bi-arrow-left"></i>
      Dashboard
    <% end %>
  </div>

  <h1 class="hero-title mb-4" data-onboarding-target="title">
    Seus dados básicos
  </h1>

  <p class="text-muted mb-4" data-onboarding-target="subtitle">
    Leva menos de 1 minuto
  </p>

  <div class="text-end mb-2">
    <small class="text-muted" data-onboarding-target="status"></small>
  </div>

  <%= form_with model: current_user, url: onboarding_path, method: :patch do |f| %>
    <div data-onboarding-target="step" class="step">
      <label class="form-label small text-muted">Nome completo</label>
      <%= f.text_field :full_name, class: "form-control mb-4", placeholder: "Nome completo", data: { action: "input->onboarding#autoSave" } %>

      <label class="form-label small text-muted">Idade</label>
      <%= f.number_field :age, class: "form-control mb-4", placeholder: "Idade", data: { action: "input->onboarding#autoSave" } %>

      <label class="form-label small text-muted">Gênero</label>
      <%= f.select :sex, User.sexes.keys.map { |s| [s.humanize, s] }, {}, class: "form-select mb-4", data: { action: "input->onboarding#autoSave" } %>

      <button type="button" class="btn btn-primary w-100"
              data-action="click->onboarding#next">
        Próximo
      </button>
    </div>

    <div data-onboarding-target="step" class="step d-none">

      <label class="form-label small text-muted">Cidade</label>
      <%= f.text_field :city, class: "form-control mb-4", placeholder: "Ex: São Paulo, Curitiba...", data: { action: "input->onboarding#autoSave" } %>

      <label class="form-label small text-muted">Estado</label>
      <%= f.text_field :state, class: "form-control mb-4", placeholder: "Ex: SP, RJ, PR...", data: { action: "input->onboarding#autoSave" } %>

      <label class="form-label small text-muted">Profissão atual</label>
      <%= f.text_field :profession, class: "form-control mb-4", placeholder: "Profissão", data: { action: "input->onboarding#autoSave" } %>

      <label class="form-label small text-muted">Rotina de trabalho</label>
      <%= f.text_field :work_routine, class: "form-control mb-4", placeholder: "Rotina profissional", data: { action: "input->onboarding#autoSave" } %>

      <div class="d-flex gap-2">
        <button type="button" class="btn btn-soft w-50"
                data-action="click->onboarding#back">
          Voltar
        </button>

        <button type="button" class="btn btn-primary w-50"
                data-action="click->onboarding#next">
          Próximo
        </button>
      </div>
    </div>

    <div data-onboarding-target="step" class="step d-none">

      <label class="form-label small text-muted">Peso atual(Kg)</label>
      <%= f.number_field :current_weight,
        class: "form-control mb-4",
        placeholder: "Peso (kg)",
        data: {
          action: "input->onboarding#formatNumber input->onboarding#autoSave"
        } %>

      <label class="form-label small text-muted">Altura(cm)</label>
      <%= f.number_field :height,
        class: "form-control mb-4",
        placeholder: "Altura (m)",
        data: {
          action: "input->onboarding#formatNumber",
          action: "input->onboarding#autoSave" 
        } %>

      <label class="form-label small text-muted">Principal objetivo</label>
      <%= f.select :main_goal,
        User.main_goals.keys.map { |g| [g.humanize, g] },
        {},
        class: "form-select mb-4", data: { action: "input->onboarding#autoSave" } %>

      <div class="form-check mb-3">
        <%= f.check_box :measured_with_tape,
          { class: "form-check-input",
            data: {
              action: "change->onboarding#toggleCircumference",
              onboarding_target: "checkbox"
            }
          },
          true,
          false %>

        <%= f.label :measured_with_tape,
          "Conseguiu medir com fita?",
          class: "form-check-label" %>
      </div>

      <label class="form-label small text-muted">Citcunferência abdominal</label>
      <div data-onboarding-target="circumferenceField" class="d-none">
        <%= f.number_field :abdominal_circumference,
          class: "form-control mb-4",
          placeholder: "Circunferência abdominal (cm)",
          data: { action: "input->onboarding#autoSave" } %>
      </div>

      <label class="form-label small text-muted">Observações sobre a medida.</label>
      <%= f.text_area :measurement_notes,
        class: "form-control mb-4",
        placeholder: "Observação (opcional)",
        data: { action: "input->onboarding#autoSave" } %>

      <label class="form-label small text-muted">Principal desconforto</label>
      <%= f.text_area :main_discomfort,
        class: "form-control mb-4",
        placeholder: "O que mais te incomoda hoje?",
        rows: 4,
        data: { action: "input->onboarding#autoSave" } %>

      <div class="d-flex gap-2">
        <button type="button" class="btn btn-soft w-50"
                data-action="click->onboarding#back">
          Voltar
        </button>

        <%= f.submit "Finalizar", class: "btn btn-primary w-50" %>
      </div>
    </div>
  <% end %>

</div>
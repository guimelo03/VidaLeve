<div class="container py-5" style="max-width: 520px;">

  <p class="hero-label">
    COMPLETE SEU PERFIL
  </p>

  <h1 class="hero-title mb-3">
    Vamos te conhecer melhor
  </h1>

  <p class="text-muted mb-4">
    Essas informações nos ajudam a personalizar sua experiência.
  </p>

  <%= form_with model: current_user, url: onboarding_path, method: :patch do |f| %>

    <div class="mb-3">
      <%= f.text_field :full_name, class: "form-control", placeholder: "Nome completo" %>
    </div>

    <div class="mb-3">
      <%= f.number_field :age, class: "form-control", placeholder: "Idade" %>
    </div>

    <div class="mb-3">
      <%= f.select :sex,
        User.sexes.keys.map { |s| [s.humanize, s] },
        {},
        class: "form-select" %>
    </div>

    <div class="mb-3">
      <%= f.text_field :city, class: "form-control", placeholder: "Cidade" %>
    </div>

    <div class="mb-3">
      <%= f.text_field :state, class: "form-control", placeholder: "Estado" %>
    </div>

    <div class="mb-3">
      <%= f.text_field :profession, class: "form-control", placeholder: "Profissão" %>
    </div>

    <div class="mb-4">
      <%= f.text_field :work_routine, class: "form-control", placeholder: "Rotina de trabalho" %>
    </div>

    <%= f.submit "Salvar e continuar", class: "btn btn-primary w-100" %>

  <% end %>

</div>
<div class="container-lg py-5">

  <div class="row">
    <div class="col-lg-8">

      <div class="row">
        <div class="col-md-6 mb-4">
          <div class="bg-white p-4 rounded-4 shadow-sm h-100">
            <h5 class="mb-3">Dados pessoais</h5>

            <p><strong>Idade:</strong> <%= @user.age %></p>
            <p><strong>Sexo:</strong> <%= @user.sex&.humanize %></p>
            <p><strong>Cidade:</strong> <%= @user.city %> - <%= @user.state %></p>
            <p><strong>Profissão:</strong> <%= @user.profession %></p>
            <p><strong>Rotina:</strong> <%= @user.work_routine %></p>
          </div>
        </div>

        <div class="col-md-6 mb-4">
          <div class="bg-white p-4 rounded-4 shadow-sm h-100">
            <h5 class="mb-3">Informações fisiológicas</h5>

            <p><strong>Peso:</strong> <%= @user.current_weight %> kg</p>
            <p><strong>Altura:</strong> <%= @user.height %> m</p>
            <p><strong>Circunferência:</strong> <%= @user.abdominal_circumference %> cm</p>

            <p><strong>Mediu com fita:</strong>
              <%= @user.measured_with_tape ? "Sim" : "Não" %>
            </p>

            <% if @user.measurement_notes.present? %>
              <p><strong>Observação:</strong> <%= @user.measurement_notes %></p>
            <% end %>

            <p><strong>Objetivo:</strong> <%= @user.main_goal&.humanize %></p>
          </div>
        </div>
      </div>
    </div>

    <div class="col-lg-4 d-flex justify-content-end">
      <div class="profile-sidebar text-center me-4">

        <div class="avatar-large mb-3">
          <i class="bi bi-person"></i>
        </div>

        <h4 class="fw-semibold mb-1">
          <%= @user.full_name.presence || @user.email %>
        </h4>

        <p class="text-muted small">
          <%= @user.email %>
        </p>

      </div>
    </div>
  </div>

</div>
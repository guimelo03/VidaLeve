<div class="container py-5 auth-fade">

  <div class="mb-4">

      <%= link_to "Voltar",
        root_path,
        class: "btn btn-soft btn-pill fw-semibold" %>

    </div>

  <div class="text-center mb-5">

    <h1 class="fw-bold mb-3">
      Como deseja entrar?
    </h1>

    <p class="text-muted">
      Escolha o tipo de acesso para continuar.
    </p>

  </div>

  <div class="row justify-content-center g-4">

    <div class="col-md-5">

      <div class="bg-white rounded-4 shadow-sm p-5 h-100 text-center">

        <div class="mb-4">

          <i class="bi bi-person-heart fs-1"></i>

        </div>

        <h3 class="fw-semibold mb-3">
          Cliente
        </h3>

        <p class="text-muted mb-4">
          Acesse suas dietas, perfil e acompanhamento.
        </p>

        <%= link_to "Entrar como cliente",
          new_user_session_path,
          class: "btn btn-primary btn-pill w-100" %>

      </div>

    </div>

    <div class="col-md-5">

      <div class="bg-white rounded-4 shadow-sm p-5 h-100 text-center">

        <div class="mb-4">

          <i class="bi bi-clipboard2-pulse fs-1"></i>

        </div>

        <h3 class="fw-semibold mb-3">
          Profissional
        </h3>

        <p class="text-muted mb-4">
          Gerencie clientes e personalize dietas.
        </p>

        <%= link_to "Entrar como profissional",
          new_professional_session_path,
          class: "btn btn-dark btn-pill w-100" %>

      </div>

    </div>

  </div>

</div>
<div class="container py-5">
  <h2 class="mb-4">
    Olá, <%= current_user.email %>
  </h2>

  <% unless current_user.has_complete_info? %>
    <div class="modal fade show" style="display:block; background: rgba(0,0,0,0.5);">
      <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content p-4 rounded-4">

          <h5 class="mb-3">Complete seu perfil</h5>

          <p class="text-muted">
            Precisamos de algumas informações para melhorar sua experiência.
          </p>

          <%= link_to "Completar agora",
            onboarding_path,
            class: "btn btn-primary w-100 mt-2" %>

        </div>
      </div>
    </div>
  <% end %>

  <div class="row">

    <div class="col-md-6 mb-4">
      <div class="p-4 bg-white rounded-4 shadow-sm">
        <h5>Seu progresso</h5>
        <p class="text-muted">Acompanhe sua evolução</p>
      </div>
    </div>

    <div class="col-md-6 mb-4">
      <div class="p-4 bg-white rounded-4 shadow-sm">
        <h5>Seu plano</h5>
        <p class="text-muted">Veja suas recomendações</p>
      </div>
    </div>

  </div>

</div>
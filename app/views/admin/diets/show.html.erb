<div class="container py-5" style="max-width: 760px;">

  <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">

    <div>
      <span class="badge bg-success-subtle text-success mb-2">
        Plano alimentar
      </span>

      <h1 class="fw-bold mb-1">
        <%= @diet.title %>
      </h1>

      <p class="text-muted mb-0">
        <%= @diet.meals.count %> refeições cadastradas
      </p>
    </div>

    <div class="d-flex flex-wrap gap-2">

      <% if current_user.professional? %>

        <%= button_to send_whatsapp_professionals_client_diet_path(@user, @diet),
          method: :post,
          class: "btn btn-primary btn-pill d-flex align-items-center gap-2" do %>

          <i class="bi bi-whatsapp"></i>
          Enviar no WhatsApp

        <% end %>

      <% end %>

      <%= link_to edit_diet_path(@user, @diet),
        class: "btn btn-primary btn-pill d-flex align-items-center gap-2" do %>

        <i class="bi bi-pencil-square"></i>
        Editar

      <% end %>

      <%= link_to diet_back_path(@diet.user),
        class: "btn btn-soft btn-pill d-flex align-items-center gap-2" do %>

        <i class="bi bi-arrow-left"></i>
        Voltar

      <% end %>

      <%= link_to destroy_diet_path(@user, @diet),
        data: {
          turbo_method: :delete,
          turbo_confirm: "Tem certeza que deseja remover esta dieta?"
        },
        class: "btn btn-danger-icon" do %>

        <i class="bi bi-trash"></i>

      <% end %>

    </div>

  </div>

  <% if @diet.meals.any? %>

    <div class="d-flex flex-column gap-4">

      <% @diet.meals.each_with_index do |meal, index| %>

        <div class="meal-card p-4">

          <div class="d-flex justify-content-between align-items-center mb-3">

            <div>
              <small class="text-muted d-block">
                Refeição <%= index + 1 %>
              </small>

              <h4 class="fw-semibold mb-0">
                <%= meal.name %>
              </h4>
            </div>

            <span class="badge bg-light text-dark">
              <%= pluralize(meal.meal_items.count, "item") %>
            </span>

          </div>

          <% if meal.meal_items.any? %>

            <div class="d-flex flex-column gap-2">

              <% meal.meal_items.each do |item| %>

                <div class="bg-light rounded-4 px-3 py-2 d-flex justify-content-between align-items-center">

                  <div class="fw-medium">
                    <%= item.name %>
                  </div>

                  <small class="text-muted">
                    <%= item.quantity %>
                  </small>

                </div>

              <% end %>

            </div>

          <% else %>

            <div class="bg-light rounded-4 p-3 text-muted">
              Nenhum alimento cadastrado.
            </div>

          <% end %>

        </div>

      <% end %>

    </div>

  <% else %>

    <div class="bg-white rounded-4 shadow-sm p-5 text-center">

      <i class="bi bi-journal-x fs-1 text-muted"></i>

      <h5 class="mt-3">
        Nenhuma refeição cadastrada
      </h5>

      <p class="text-muted mb-0">
        Essa dieta ainda não possui refeições adicionadas.
      </p>

    </div>

  <% end %>

</div>
<div class="container py-5" data-controller="nested-form" style="max-width: 720px;">

  <%= form_with model: [:admin, @user, @diet], local: true do |f| %>

    <%= f.text_field :title,
      class: "form-control mb-4",
      placeholder: "Nome da dieta" %>

    <div data-nested-form-target="meals">

      <%= f.fields_for :meals do |meal_form| %>

        <div class="meal-card p-4 mb-4"
             data-meal
             data-removable
             data-index="<%= meal_form.index %>">

          <div class="d-flex justify-content-between align-items-center mb-3">

            <%= meal_form.hidden_field :id %>
            <%= meal_form.hidden_field :_destroy, value: 0 %>

            <%= meal_form.text_field :name,
              class: "form-control flex-grow-1",
              placeholder: "Nome da refeição" %>

            <button type="button"
              class="btn btn-danger-icon ms-2"
              data-action="click->nested-form#removeElement">
              <i class="bi bi-x"></i>
            </button>

          </div>

          <div data-items-container>

            <%= meal_form.fields_for :meal_items do |item_form| %>

              <div class="d-flex gap-2 mb-2" data-removable>

                <%= item_form.hidden_field :id %>
                <%= item_form.hidden_field :_destroy, value: 0 %>

                <%= item_form.text_field :name,
                  class: "form-control flex-grow-1",
                  placeholder: "Alimento" %>

                <%= item_form.text_field :quantity,
                  class: "form-control flex-grow-1",
                  placeholder: "Qtd" %>

                <button type="button"
                  class="btn btn-danger-icon ms-2"
                  data-action="click->nested-form#removeElement">
                  <i class="bi bi-x"></i>
                </button>

              </div>

            <% end %>

          </div>

          <div data-items-template>
            <template>
              <div class="d-flex gap-2 mb-2" data-removable>

                <input type="text"
                  name="diet[meals_attributes][MEAL_INDEX][meal_items_attributes][ITEM_INDEX][name]"
                  class="form-control flex-grow-1"
                  placeholder="Alimento">

                <input type="text"
                  name="diet[meals_attributes][MEAL_INDEX][meal_items_attributes][ITEM_INDEX][quantity]"
                  class="form-control flex-grow-1"
                  placeholder="Qtd">

                <button type="button"
                  class="btn btn-danger-icon ms-2"
                  data-action="click->nested-form#removeElement">
                  <i class="bi bi-x"></i>
                </button>

              </div>
            </template>
          </div>

          <button type="button"
            class="btn btn-soft btn-pill mt-2"
            data-action="click->nested-form#addItem">
            + Adicionar alimento
          </button>

        </div>

      <% end %>

    </div>

    <template data-nested-form-target="mealTemplate">
        <div class="meal-card p-4 mb-4"
            data-meal
            data-removable
            data-index="MEAL_INDEX">

            <div class="d-flex justify-content-between align-items-center mb-3">

            <input type="text"
                name="diet[meals_attributes][MEAL_INDEX][name]"
                class="form-control flex-grow-1"
                placeholder="Ex: Café da manhã">

            <button type="button"
                class="btn btn-danger-icon ms-2"
                data-action="click->nested-form#removeElement">
                <i class="bi bi-x"></i>
            </button>

            </div>

            <div data-items-container></div>

            <div data-items-template>
            <template>
                <div class="d-flex gap-2 mb-2" data-removable>

                <input type="text"
                    name="diet[meals_attributes][MEAL_INDEX][meal_items_attributes][ITEM_INDEX][name]"
                    class="form-control flex-grow-1"
                    placeholder="Alimento">

                <input type="text"
                    name="diet[meals_attributes][MEAL_INDEX][meal_items_attributes][ITEM_INDEX][quantity]"
                    class="form-control flex-grow-1"
                    placeholder="Qtd">

                </div>
            </template>
            </div>

            <button type="button"
            class="btn btn-soft btn-pill mt-2"
            data-action="click->nested-form#addItem">
            + Adicionar alimento
            </button>

        </div>
        </template>

    <button type="button"
      class="btn btn-soft btn-pill w-100 mt-3"
      data-action="click->nested-form#addMeal">
      + Adicionar refeição
    </button>

    <%= f.submit "Atualizar dieta",
      class: "btn btn-primary btn-pill w-100 mt-3" %>

  <% end %>

</div>

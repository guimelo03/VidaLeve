<div class="container py-5">

  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Detalhes do cliente</h2>

    <%= link_to "Voltar",
      admin_users_path,
      class: "btn btn-soft btn-pill" %>
  </div>

  <div class="row">

    <div class="col-md-6 mb-4">
      <div class="bg-white p-4 rounded-4 shadow-sm">
        <h5 class="mb-3">Dados pessoais</h5>

        <p><strong>Nome:</strong> <%= @user.full_name %></p>
        <p><strong>Email:</strong> <%= @user.email %></p>
        <p><strong>Idade:</strong> <%= @user.age %></p>
        <p><strong>Sexo:</strong> <%= @user.sex&.humanize %></p>
        <p><strong>Cidade:</strong> <%= @user.city %> - <%= @user.state %></p>
        <p><strong>Profissão:</strong> <%= @user.profession %></p>
      </div>
    </div>

    <div class="col-md-6 mb-4">
      <div class="bg-white p-4 rounded-4 shadow-sm">
        <h5 class="mb-3">Informações físicas</h5>

        <p><strong>Peso:</strong> <%= @user.current_weight %> kg</p>
        <p><strong>Altura:</strong> <%= @user.height %> m</p>

        <p><strong>Mediu com fita:</strong>
          <%= @user.measured_with_tape ? "Sim" : "Não" %>
        </p>

        <% if @user.measured_with_tape? %>
          <p><strong>Circunferência:</strong> <%= @user.abdominal_circumference %> cm</p>
        <% end %>

        <% if @user.measurement_notes.present? %>
          <p><strong>Observações:</strong> <%= @user.measurement_notes %></p>
        <% end %>

        <p><strong>Objetivo:</strong> <%= @user.main_goal&.humanize %></p>
      </div>
    </div>

  </div>

  <div class="bg-white p-4 rounded-4 shadow-sm">
    <h5 class="mb-3">O que mais incomoda</h5>
    <p><%= @user.main_discomfort %></p>
  </div>

  <div class="bg-white p-4 rounded-4 shadow-sm mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
      <h5 class="mb-0">Dietas do cliente</h5>

      <%= link_to "Nova dieta",
        new_admin_user_diet_path(@user),
        class: "btn btn-primary btn-pill btn-sm" %>
    </div>

    <% if @diets.any? %>

      <% @diets.each do |diet| %>

        <div class="d-flex justify-content-between align-items-center border rounded-4 p-3 mb-3">

          <div>
            <h6 class="fw-semibold mb-1"><%= diet.title %></h6>
            <small class="text-muted">
              Criada em <%= diet.created_at.strftime("%d/%m/%Y") %>
            </small>
          </div>

          <%= link_to "Ver detalhes",
            admin_user_diet_path(@user, diet),
            class: "btn btn-soft btn-pill btn-sm" %>

        </div>

      <% end %>

    <% else %>

      <p class="text-muted mb-0">
        Nenhuma dieta cadastrada ainda.
      </p>

    <% end %>

  </div>

</div>
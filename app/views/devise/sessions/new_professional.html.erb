<div class="container py-5 fade-up" style="max-width: 480px;">

  <div class="mb-4">

    <%= link_to "Voltar",
      login_path,
      class: "btn btn-soft btn-pill" %>

  </div>

  <div class="bg-white p-5 rounded-4 shadow-sm">

    <div class="text-center mb-4">

      <div class="mb-3">
        <i class="bi bi-clipboard2-pulse fs-1"></i>
      </div>

      <h2 class="fw-bold mb-2">
        Área profissional
      </h2>

      <p class="text-muted mb-0">
        Entre para gerenciar seus clientes e dietas.
      </p>

    </div>

    <%= form_with url: professional_session_path,
      local: true do |f| %>

      <div class="mb-3">

        <%= email_field_tag :email,
          nil,
          class: "form-control",
          placeholder: "Seu email",
          required: true,
          autofocus: true %>

      </div>

      <div class="mb-4">

        <%= password_field_tag :password,
          nil,
          class: "form-control",
          placeholder: "Sua senha",
          required: true %>

      </div>

      <%= f.submit "Entrar",
        class: "btn btn-primary btn-pill w-100" %>

    <% end %>

    <div class="text-center mt-4">

      <p class="text-muted mb-2">
        Ainda não possui acesso profissional?
      </p>

      <%= link_to "Criar conta profissional",
        new_professional_registration_path,
        class: "btn btn-soft btn-pill" %>

    </div>

  </div>

</div>
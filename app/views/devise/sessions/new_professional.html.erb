<div class="auth-page-wrapper">

  <div class="auth-card">

    <div class="text-center mb-4">

      <h1 class="fw-bold mb-2">
        Área profissional
      </h1>

      <p class="text-muted mb-0">
        Entre para gerenciar seus clientes.
      </p>

    </div>

    <%= form_with url: professional_session_path,
      local: true do |f| %>

      <div class="mb-3">

        <%= email_field_tag :email,
          nil,
          class: "form-control",
          placeholder: "Seu email",
          required: true,
          autofocus: true %>

      </div>

      <div class="mb-4">

        <%= password_field_tag :password,
          nil,
          class: "form-control",
          placeholder: "Sua senha",
          required: true %>

      </div>

      <%= f.submit "Entrar",
        class: "btn btn-primary btn-pill w-100" %>

    <% end %>

    <div class="text-center mt-4">

      <small class="text-muted">
        Área exclusiva para profissionais.
      </small>

    </div>

  </div>

</div>
<div class="container py-5 auth-fade" style="max-width: 480px;">

  <div class="mb-4">

    <%= link_to "Voltar",
      root_path,
      class: "btn btn-soft btn-pill" %>

  </div>

  <div class="bg-white p-5 rounded-4 shadow-sm">

    <div class="text-center mb-4">

      <div class="mb-3">
        <i class="bi bi-person-badge fs-1"></i>
      </div>

      <h2 class="fw-bold mb-2">
        Cadastro profissional
      </h2>

      <p class="text-muted mb-0">
        Crie sua conta para começar a gerenciar seus clientes.
      </p>

    </div>

    <%= form_with model: resource,
      url: professional_registration_path,
      local: true do |f| %>

      <div class="mb-3">

        <%= f.text_field :full_name,
          class: "form-control",
          placeholder: "Seu nome",
          required: true %>

      </div>

      <div class="mb-3">

        <%= f.email_field :email,
          class: "form-control",
          placeholder: "Seu email",
          required: true %>

      </div>

      <div class="mb-3">

        <%= f.password_field :password,
          class: "form-control",
          placeholder: "Sua senha",
          required: true %>

      </div>

      <div class="mb-4">

        <%= f.password_field :password_confirmation,
          class: "form-control",
          placeholder: "Confirmar senha",
          required: true %>

      </div>

      <%= f.submit "Criar conta",
        class: "btn btn-primary btn-pill w-100" %>

    <% end %>

    <div class="text-center mt-4">

      <p class="text-muted mb-2">
        Já possui uma conta?
      </p>

      <%= link_to "Entrar",
        new_professional_session_path,
        class: "btn btn-soft btn-pill" %>

    </div>

  </div>

</div>
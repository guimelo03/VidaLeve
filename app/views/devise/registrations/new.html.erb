<div class="container py-5" style="max-width: 420px;">
  <h2 class="mb-4">Criar conta</h2>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
    
    <div class="mb-3">
      <%= f.email_field :email, class: "form-control", placeholder: "Email" %>
    </div>

    <div class="mb-3">
      <%= f.password_field :password, class: "form-control", placeholder: "Senha" %>
    </div>

    <div class="mb-3">
      <%= f.password_field :password_confirmation, class: "form-control", placeholder: "Confirmar senha" %>
    </div>

    <%= f.submit "Criar conta", class: "btn btn-primary w-100 btn-pill" %>
  <% end %>

  <div class="mt-3 text-center">
    <%= link_to "Já tem conta? Entrar", new_session_path(resource_name), class: "btn btn-soft btn-pill" %>
  </div>
</div>
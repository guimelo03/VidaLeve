<div class="container py-5 fade-up" style="max-width: 480px;">

  <div class="mb-4">

    <%= link_to "Voltar",
      root_path,
      class: "btn btn-soft btn-pill" %>

  </div>

  <div class="bg-white p-5 rounded-4 shadow-sm">

    <div class="text-center mb-4">

      <div class="mb-3">
        <i class="bi bi-person-plus fs-1"></i>
      </div>

      <h2 class="fw-bold mb-2">
        Criar conta
      </h2>

      <p class="text-muted mb-0">
        Comece sua jornada de forma personalizada.
      </p>

    </div>

    <%= form_for(resource,
      as: resource_name,
      url: registration_path(resource_name)) do |f| %>

      <div class="mb-3">

        <%= f.email_field :email,
          class: "form-control",
          placeholder: "Email" %>

      </div>

      <div class="mb-3">

        <%= f.password_field :password,
          class: "form-control",
          placeholder: "Senha" %>

      </div>

      <div class="mb-4">

        <%= f.password_field :password_confirmation,
          class: "form-control",
          placeholder: "Confirmar senha" %>

      </div>

      <%= f.submit "Criar conta",
        class: "btn btn-primary btn-pill w-100" %>

    <% end %>

    <div class="text-center mt-4">

      <p class="text-muted mb-2">
        Já possui uma conta?
      </p>

      <%= link_to "Entrar",
        new_session_path(resource_name),
        class: "btn btn-soft btn-pill" %>

    </div>

  </div>

</div>
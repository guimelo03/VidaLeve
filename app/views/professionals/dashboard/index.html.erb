<div class="container-lg py-5">


  <div class="d-flex justify-content-between align-items-center mb-5">

    <div>
      <h1 class="fw-bold mb-1">
        Olá, <%= professional_saudation %>
      </h1>

      <p class="text-muted mb-0">
        Gerencie clientes e acompanhe dietas recentes.
      </p>
    </div>

  </div>

  <div class="row g-4 mb-5">

    <div class="col-md-4">

      <div class="dashboard-card h-100">

        <div class="d-flex justify-content-between align-items-center mb-3">

          <h5 class="mb-0">Clientes</h5>

          <i class="bi bi-people fs-4"></i>

        </div>

        <h2 class="fw-bold">
          <%= current_user.clients.count %>
        </h2>

      </div>

    </div>

    <div class="col-md-4">

      <div class="dashboard-card h-100">

        <div class="d-flex justify-content-between align-items-center mb-3">

          <h5 class="mb-0">Dietas</h5>

          <i class="bi bi-journal-medical fs-4"></i>

        </div>

        <h2 class="fw-bold">
          <%= professional_client_diets %>
        </h2>

      </div>

    </div>

    <div class="col-md-4">

      <div class="dashboard-card h-100">

        <div class="d-flex justify-content-between align-items-center mb-3">

          <h5 class="mb-0">Perfis completos</h5>

          <i class="bi bi-check-circle fs-4"></i>

        </div>

        <h2 class="fw-bold">
          <%= completed_clients_profile %>
        </h2>

      </div>

    </div>

  </div>

  <div class="row g-4">

    <div class="col-lg-6">

      <div class="dashboard-card h-100">

        <div class="d-flex justify-content-between align-items-center mb-4">

          <h4 class="mb-0">
            Clientes recentes
          </h4>

        </div>

        <% if current_user.clients.empty? %>
          <p class="text-muted mb-0">
            Nenhum cliente atribuído ainda.
          </p>


        <% else %>
          <% @clients.each do |client| %>

            <div class="dashboard-list-item">

              <div>

                <h6 class="mb-1">
                  <%= client.full_name.presence || client.email %>
                </h6>

                <small class="text-muted">
                  <%= client.email %>
                </small>

              </div>

              <%= link_to "Ver",
                professionals_client_path(client),
                class: "btn btn-soft btn-sm btn-pill" %>

            </div>

          <% end %>
        <% end %>
      </div>

    </div>

    <div class="col-lg-6">

      <div class="dashboard-card h-100">

        <div class="d-flex justify-content-between align-items-center mb-4">

          <h4 class="mb-0">
            Dietas recentes
          </h4>

        </div>
        
        <% if current_user.client_diets.blank? %>
          <p class="text-muted mb-0">
            Nenhuma dieta criada por você ainda.
          </p>

        <% else %>

          <% @recent_diets.each do |diet| %>

            <div class="dashboard-list-item">

              <div>

                <h6 class="mb-1">
                  <%= diet.title %>
                </h6>

                <small class="text-muted">
                  <%= diet.user.full_name.presence || diet.user.email %>
                </small>

              </div>

              <%= link_to "Ver",
                professionals_client_diet_path(diet.user, diet),
                class: "btn btn-soft btn-sm btn-pill" %>

            </div>

          <% end %>
        <% end %>
      </div>
    </div>
  </div>
</div>
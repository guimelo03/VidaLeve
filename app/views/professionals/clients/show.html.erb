<div class="container py-5">

  <div class="d-flex justify-content-between align-items-center mb-4">

    <h2>
      Detalhes do cliente
    </h2>

    <%= link_to "Voltar",
      professionals_clients_path,
      class: "btn btn-soft btn-pill" %>

  </div>

  <div class="row">

    <div class="col-lg-8">

      <%= render "users/client_info",
        user: @client %>

      <%= render "users/client_diets",
        user: @client,
        diets: @diets,
        view_context: :professional 
      %>

    </div>

    <div class="col-lg-4 d-flex justify-content-end">

      <%= render "users/profile_sidebar",
        user: @client %>

    </div>

  </div>

</div>
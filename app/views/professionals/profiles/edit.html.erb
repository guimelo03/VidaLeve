<div class="container-lg py-5">

  <div class="mb-4">

    <%= link_to professionals_profile_path,
      class: "btn btn-soft btn-pill" do %>

      <i class="bi bi-arrow-left"></i>
      Voltar

    <% end %>

  </div>

  <%= form_with model: @user,
    url: professionals_profile_path,
    method: :patch do |f| %>

    <div class="row">

      <div class="col-lg-8">

        <%= render "users/profile_section",
          title: "Informações profissionais" do %>

          <div class="mb-3">

            <strong>Nome completo:</strong>

            <%= f.text_field :full_name,
              class: "form-control mt-1" %>

          </div>

          <div class="mb-3">

            <strong>E-mail:</strong>

            <input type="text"
                   class="form-control mt-1"
                   value="<%= @user.email %>"
                   disabled>

          </div>

          <div class="mb-3">

            <strong>Telefone:</strong>

            <%= f.telephone_field :phone,
              class: "form-control mt-1",
              inputmode: "numeric",
              data: { controller: "phone" } %>

          </div>

        <% end %>

      </div>

      <div class="col-lg-4 d-flex justify-content-end">

        <div class="profile-sidebar me-4">

          <div class="avatar-large mb-3">
            <i class="bi bi-person"></i>
          </div>

          <h4 class="fw-semibold mb-1">
            <%= @user.full_name.presence || @user.email %>
          </h4>

          <p class="text-muted small">
            <%= @user.email %>
          </p>

          <div class="mt-3 d-grid gap-2">

            <%= f.submit "Salvar alterações",
              class: "btn btn-primary btn-pill" %>

            <%= link_to "Cancelar",
              professionals_profile_path,
              class: "btn btn-soft btn-pill" %>

          </div>

        </div>

      </div>

    </div>

  <% end %>

</div>